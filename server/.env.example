PORT=5001
NODE_ENV=development

# Database Configuration
# Replace with your local or MongoDB Atlas string
MONGO_URI=mongodb://localhost:27017/smm_panel

# Authentication Secrets
# Use a long random string for production
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# SMM Provider API (e.g., SMMGen)
SMMGEN_API_URL=https://smmgen.com/api/v2
SMMGEN_API_KEY=your_api_key_here
